{
  "name": "quick-nav-extension",
  "displayName": "Quick nav extension",
  "version": "0.0.2",
  "description": "QuickNav - 智能导航助手：打造专属个人导航站，一键直达常用网站和工具",
  "author": "liufrank621@gmail.com",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*"
    ],
    "permissions": [
      "tabs",
      "storage",
      "contextMenus"
    ],
    "action": {
      "default_popup": "popup.html",
      "default_title": "Quick Nav - 快速添加导航"
    }
  }
}
